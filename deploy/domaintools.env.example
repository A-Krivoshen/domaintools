# Copy to /etc/domaintools/domaintools.env
# chmod 600 /etc/domaintools/domaintools.env
# chown root:www-data /etc/domaintools/domaintools.env
#
# Loaded by deploy/systemd/python-domaintools.service

# Required for gunicorn (wsgi.py refuses to start without this)
SECRET_KEY=replace-with-long-random-string

# Redis (required for history, jobs, rate limits)
REDIS_URL=redis://127.0.0.1:6379/3
JOB_STORAGE_ALLOW_LOCAL_FALLBACK=0

# Agent API (disabled by default)
AGENT_API_ENABLED=0
AGENT_API_KEY=

# Optional tuning
# AGENT_API_RATE_LIMIT_PER_MIN=30
# AGENT_API_REPORT_RATE_LIMIT_PER_MIN=10
# TOOL_RATE_LIMIT_PER_MIN=20
# DOMAINS_RATE_LIMIT_PER_MIN=10
# SITE_CHECKER_RATE_LIMIT_PER_MIN=15
# SECURITY_RATE_LIMIT_PER_MIN=15

# SEO / IndexNow (enabled by default in production; pings Bing/Yandex on successful lookups)
# SITE_CANONICAL_ROOT=https://domaintools.site
# INDEXNOW_ENABLED=1
# INDEXNOW_KEY=optional-32-char-key-or-auto-from-secret
# INDEXNOW_DEBOUNCE_S=600
# INDEXNOW_DISABLED=1
# SITEMAP_ZONE_LIMIT=60

# Local development only (python app.py / flask run):
# FLASK_DEBUG=1